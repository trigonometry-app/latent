{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "latent",
  "main": "dist-worker.js",
  "compatibility_date": "2026-02-22",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "routes": [
    { "pattern": "latent.kendell.dev", "zone_name": "kendell.dev" },
  ],
}
